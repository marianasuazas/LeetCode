class Solution:
    def eraseOverlapIntervals(self, intervals: List[List[int]]) -> int:
      n =len(intervals) 
      max_valid = 0
      for k in range(n + 1):
        for subset in combinations(intervals, k):
          subset = sorted(subset, key=lambda x: x[0])
          valid = True
          for i in range(1, len(subset)):
            if subset[i][0] < subset[i-1][1]:
              valid = False
              break
          if valid:
            max_valid = max(max_valid, len(subset))
      return n - max_valid


"Complejidad temporal: O(2^n * n log n)Porque hay 2^n subconjuntos y en el peor caso cada uno se ordena en O(n log n)“
“Complejidad espacial: O(n) Porque solo se almacena un subconjunto a la vez (no todos simultáneamente)"
